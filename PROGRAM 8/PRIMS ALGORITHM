#include <stdio.h>

#define MAX 100
#define INF 9999

int main() {
    int graph[MAX][MAX], n;
    int selected[MAX];
    int no_edge = 0;

    printf("Enter number of vertices: ");
    scanf("%d", &n);

    printf("Enter adjacency matrix:\n");

    for (int i = 0; i < n; i++) {
        for (int j = 0; j < n; j++) {
            scanf("%d", &graph[i][j]);


            if (i != j && graph[i][j] == 0)
                graph[i][j] = INF;
        }
    }


    for (int i = 0; i < n; i++)
        selected[i] = 0;


    selected[0] = 1;

    int totalCost = 0;

    printf("\nEdges in Minimum Spanning Tree:\n");

    while (no_edge < n - 1) {

        int min = INF;
        int x = 0, y = 0;

        for (int i = 0; i < n; i++) {
            if (selected[i]) {
                for (int j = 0; j < n; j++) {
                    if (!selected[j] && graph[i][j] < min) {
                        min = graph[i][j];
                        x = i;
                        y = j;
                    }
                }
            }
        }

        printf("%d - %d : %d\n", x, y, graph[x][y]);

        totalCost += graph[x][y];

        selected[y] = 1;
        no_edge++;
    }

    printf("\nMinimum Cost = %d\n", totalCost);

    return 0;
}
