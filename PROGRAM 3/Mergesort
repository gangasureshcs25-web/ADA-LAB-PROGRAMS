#include <stdio.h>
#include <stdlib.h>
#include <time.h>

int a[100000], temp[100000];

void merge(int low, int mid, int high)
{
    int i = low, j = mid + 1, k = low;

    while(i <= mid && j <= high)
    {
        if(a[i] <= a[j])
            temp[k++] = a[i++];
        else
            temp[k++] = a[j++];
    }

    while(i <= mid)
        temp[k++] = a[i++];

    while(j <= high)
        temp[k++] = a[j++];

    for(i = low; i <= high; i++)
        a[i] = temp[i];
}

void mergesort(int low, int high)
{
    int mid;

    if(low < high)
    {
        mid = (low + high) / 2;
        mergesort(low, mid);
        mergesort(mid + 1, high);
        merge(low, mid, high);
    }
}

int main()
{
    int n, i;
    clock_t start, end;
    double time_taken;

    printf("Enter number of elements: ");
    scanf("%d", &n);

    srand(time(NULL));

    for(i = 0; i < n; i++)
        a[i] = rand();

    start = clock();

    mergesort(0, n - 1);

    end = clock();

    time_taken = ((double)(end - start)) / CLOCKS_PER_SEC*(1000);

    printf("\nNumber of elements = %d", n);
    printf("\nTime taken = %f seconds\n", time_taken);

    return 0;
}
