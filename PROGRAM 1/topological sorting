#include <stdio.h>

#define MAX 20

int main() {
    int n, i, j, k;
    int adj[MAX][MAX];
    int indegree[MAX] = {0};
    int queue[MAX], front = 0, rear = -1;
    int topo[MAX], count = 0;

    printf("Enter number of vertices: ");
    scanf("%d", &n);

    printf("Enter adjacency matrix:\n");
    for(i = 0; i < n; i++) {
        for(j = 0; j < n; j++) {
            scanf("%d", &adj[i][j]);
        }
    }


    for(i = 0; i < n; i++) {
        for(j = 0; j < n; j++) {
            if(adj[i][j] == 1)
                indegree[j]++;
        }
    }


    for(i = 0; i < n; i++) {
        if(indegree[i] == 0)
            queue[++rear] = i;
    }


    while(front <= rear) {
        k = queue[front++];
        topo[count++] = k;

        for(j = 0; j < n; j++) {
            if(adj[k][j] == 1) {
                indegree[j]--;
                if(indegree[j] == 0)
                    queue[++rear] = j;
            }
        }
    }


    if(count != n) {
        printf("Graph has a cycle. Topological ordering not possible.\n");
    } else {
        printf("Topological Ordering:\n");
        for(i = 0; i < n; i++) {
            printf("%d ", topo[i]);
        }
        printf("\n");
    }

    return 0;
}
